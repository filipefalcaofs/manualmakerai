## Cards — padrao de montagem

### Estrutura XML

```xml
<!-- Card body -->
<component COM_CODIGO="ID1" COM_TIPO="P" name="MakerContainer1">
    <property name="NomeClasseCss">form-group card</property>
    <property name="Container"></property>  <!-- raiz da aba -->
    <!-- posicao e tamanho -->
</component>

<!-- Card header -->
<component COM_CODIGO="ID2" COM_TIPO="P" name="MakerContainer2">
    <property name="NomeClasseCss">form-group card-header</property>
    <property name="Container">MakerContainer1</property>  <!-- filho do card -->
    <property name="PosicaoX">0</property>
    <property name="PosicaoY">0</property>
    <property name="Tamanho">MESMA_LARGURA_DO_CARD</property>
    <property name="Altura">40</property>
</component>

<!-- Label do header -->
<component COM_CODIGO="ID3" COM_TIPO="L" name="MakerLabel2">
    <property name="Container">MakerContainer2</property>  <!-- filho do header -->
    <property name="Descricao">HTML_COM_ICONE_E_TITULO</property>
    <property name="PosicaoX">10</property>
    <property name="PosicaoY">5</property>
</component>
```

