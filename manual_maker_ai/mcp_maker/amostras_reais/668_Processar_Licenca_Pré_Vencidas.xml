<PARAMS>
<CONSTANT TYPE="Letras" NULL="FALSE"  >SELECT
COUNT(*)&#x20;OVER&#x20;()&#x20;AS&#x20;n,
VS_CGI_LICENCA.LIC_COD,
VS_CGI_LICENCA.PES_COD_PERMISSIONARIO,
VS_CGI_LICENCA.LIC_NUMERO,
VS_CGI_LICENCA.LIC_VALIDADE,
VS_CGI_LICENCA.LIC_DATA_BASE_VENCIMENTO,
VS_CGI_LICENCA.LIC_VALIDADE_CARENCIA,
CONVERT(VARCHAR(16),GETDATE(),103)&#x20;as&#x20;HOJE,
CONVERT(VARCHAR(16),GETDATE(),103)+'&#x20;'+CONVERT(VARCHAR(16),GETDATE(),108)&#x20;AS&#x20;HORA,
VS_CGI_LICENCA.PES_EMAIL_PERM,
VS_CGI_LICENCA.PES_EMAIL_STATUS_PERM,
CGI_CONFIG.CFG_EMAIL_ATIVO,
VS_CGI_LICENCA.PES_NOME_PERM,
CGI_CONFIG.CFG_FIN_PAR,
VS_CGI_LICENCA.LIC_VENCIDA,
VS_CGI_LICENCA.NOVO_VALOR_TITULO,
VS_CGI_LICENCA.LIC_SITUACAO,
VS_LICENCA_STATUS_FIN.LIC_INADIMPLENTE,
VS_CGI_PESSOA.PES_EMAIL_STATUS,
VS_CGI_LICENCA.LIC_LEGADO,
VS_CGI_LICENCA.FPG_COD,
CGI_FORMA_PAG.FPG_ENTRADA,
CGI_FORMA_PAG.FPG_N_PARCELAS,
CGI_FORMA_PAG.FPG_INTERVALO,
CGI_FORMA_PAG.PFG_RETARDAR
FROM&#x20;VS_CGI_LICENCA&#x20;
Inner&#x20;Join&#x20;VS_LICENCA_STATUS_FIN&#x20;On&#x20;VS_CGI_LICENCA.LIC_COD&#x20;=&#x20;VS_LICENCA_STATUS_FIN.LIC_COD
inner&#x20;join&#x20;VS_CGI_PESSOA&#x20;on&#x20;VS_CGI_LICENCA.PES_COD_PERMISSIONARIO&#x20;=&#x20;VS_CGI_PESSOA.PES_COD
inner&#x20;join&#x20;CGI_FORMA_PAG&#x20;on&#x20;VS_CGI_LICENCA.FPG_COD&#x20;=&#x20;CGI_FORMA_PAG.FPG_COD
,&#x20;CGI_CONFIG
WHERE
VS_LICENCA_STATUS_FIN.LIC_INADIMPLENTE&#x20;like&#x20;'N%'
and&#x20;CAST(VS_CGI_LICENCA.LIC_VALIDADE&#x20;as&#x20;date)&#x20;between&#x20;CAST(GETDATE()&#x20;as&#x20;date)&#x20;and&#x20;CAST(dateadd(day,&#x20;CGI_CONFIG.CFG_FIN_PAR,&#x20;GETDATE())&#x20;as&#x20;date)
and&#x20;VS_CGI_LICENCA.LIC_VENCIDA&#x20;like&#x20;'N%'
and&#x20;VS_CGI_LICENCA.LIC_SITUACAO&#x20;=&#x20;'LDF'
and&#x20;
(select&#x20;count(VS_CGI_TITULO.TTL_COD)&#x20;from&#x20;VS_CGI_TITULO&#x20;where&#x20;VS_CGI_TITULO.LIC_COD&#x20;=&#x20;VS_CGI_LICENCA.LIC_COD&#x20;
and&#x20;VS_CGI_TITULO.TTL_SITUACAO&#x20;=&#x20;'A'
)&#x20;=&#x20;0
order&#x20;by
VS_CGI_LICENCA.lic_cod</CONSTANT>
<CONSTANT TYPE="Letras" NULL="TRUE"  ></CONSTANT>
<CONSTANT TYPE="Inteiro" NULL="TRUE"  ></CONSTANT>
<CONSTANT TYPE="Letras" NULL="TRUE"  ></CONSTANT>
</PARAMS>
</FUNCTION>
